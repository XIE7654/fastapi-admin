# 环境配置示例
# 复制此文件为 .env 并修改配置

# 应用配置
APP_NAME=芋道管理系统
DEBUG=false
HOST=0.0.0.0
PORT=8000

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=ruoyi-vue-pro
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# Redis配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET_KEY=your-secret-key-please-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=43200

# 多租户配置
TENANT_ENABLE=true

# 日志配置
LOG_LEVEL=INFO